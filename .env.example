# --- Environment ---
ENVIRONMENT=development           # development | staging | production
SITE_ADDRESS=:80                  # e.g. yourdomain.com for TLS via Caddy

# --- Database ---
POSTGRES_USER=gym
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=gym

# --- Backend ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-super-secret-please-32+chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost:3000,http://localhost
RATE_LIMIT_LOGIN=10/minute

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Seed the exercise catalogue once on first boot (1 = run, 0 = skip).
SEED_EXERCISES=1

# --- Frontend ---
# In production with Caddy in front, leave it as `/api` (same origin).
NEXT_PUBLIC_API_URL=/api

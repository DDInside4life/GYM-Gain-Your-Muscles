# --- Environment ---
ENVIRONMENT=development           # development | staging | production
SITE_ADDRESS=:80                  # e.g. yourdomain.com for TLS via Caddy

# --- Database ---
POSTGRES_USER=gym
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=gym

# --- Backend ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-super-secret-please-32+chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost:3000,http://localhost
RATE_LIMIT_LOGIN=10/minute

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Seed the exercise catalogue once on first boot (1 = run, 0 = skip).
SEED_EXERCISES=1

# --- Frontend ---
# In production with Caddy in front, leave it as `/api` (same origin).
NEXT_PUBLIC_API_URL=/api

# --- AI / LLM (optional) ---
# Enable the multi-agent coach layer. When disabled the stack still works
# via the deterministic generator/progression/nutrition services.
AI_ENABLED=0
# Any OpenAI-compatible provider works. Groq is free + fast.
AI_PROVIDER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.1-70b-versatile
AI_TIMEOUT_S=25
AI_MAX_RETRIES=2
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2048
